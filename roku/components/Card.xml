<?xml version="1.0" encoding="utf-8" ?>
<component name="Card" extends="Group">
  <interface>
    <field id="cardWidth" type="float" onChange="onLayoutChanged" />
    <field id="cardHeight" type="float" onChange="onLayoutChanged" />
    <field id="cornerRadius" type="float" onChange="onLayoutChanged" />
    <field id="backgroundColor" type="color" onChange="onColorChanged" />
    <field id="focusBackgroundColor" type="color" onChange="onColorChanged" />
    <field id="isFocused" type="boolean" onChange="onFocusChanged" />
    <field id="showShadow" type="boolean" onChange="onShadowChanged" />
    <field id="shadowUri" type="string" onChange="onShadowChanged" />
  </interface>

  <children>
    <Poster id="shadowImage" width="100" height="100" translation="[8,10]" visible="false" />
    <Rectangle id="shadow" color="0x00000088" width="100" height="100" translation="[8,10]" opacity="0.45" />
    <Rectangle id="surface" color="0x1A232EFF" width="100" height="100" />
  </children>

  <script type="text/brightscript" uri="pkg:/source/Theme.brs" />
  <script type="text/brightscript" uri="pkg:/components/Card.brs" />
</component>
